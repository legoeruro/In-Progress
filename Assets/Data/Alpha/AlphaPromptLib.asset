%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 7f4ab8483cc94d44ba2f64f00b73d530, type: 3}
  m_Name: AlphaPromptLib
  m_EditorClassIdentifier: Assembly-CSharp::AlphaPromptLibrary
  prompts:
  - title: Citizen Identity Verification Form
    promptText: 'Please provide your full legal name as it appears on your most recent
      government-issued documentation. Illegible submissions will be rejected.

'
    requiredSlot: {fileID: 11400000, guid: 1e070433b55e14a41888779db971575d, type: 2}
    timeToCompleteSeconds: 15
  - title: Driver Registration Confirmation
    promptText: Enter your valid Driver Identification Number. Expired, provisional,
      or revoked numbers are not accepted.
    requiredSlot: {fileID: 11400000, guid: 09917be0a746973449452c593d6a7185, type: 2}
    timeToCompleteSeconds: 15
  - title: Social Security Acknowledgment
    promptText: 'Provide your assigned Social Security Number. If you do not have
      one, leave blank and wait for further instruction.

'
    requiredSlot: {fileID: 11400000, guid: 0d6a7e9ad14d61c4aaa0bec153dc4e31, type: 2}
    timeToCompleteSeconds: 15
  - title: 'Contact Trace Submission '
    promptText: Provide your primary phone number for official correspondence. International
      prefixes must be included.
    requiredSlot: {fileID: 11400000, guid: d4da788ecdbd30f41810cbdff1dd3a0e, type: 2}
    timeToCompleteSeconds: 15
  - title: Employment Eligibility Review
    promptText: To confirm your eligibility for work, submit your Social Security
      Number below.
    requiredSlot: {fileID: 11400000, guid: 0d6a7e9ad14d61c4aaa0bec153dc4e31, type: 2}
    timeToCompleteSeconds: 15
  - title: Interstate Driver Cross-Check
    promptText: Enter your Driver ID to verify your compliance with interstate transport
      regulations.
    requiredSlot: {fileID: 11400000, guid: d4da788ecdbd30f41810cbdff1dd3a0e, type: 2}
    timeToCompleteSeconds: 15
  - title: Record Consistency Audit
    promptText: 'Submit your full legal name for record reconciliation. Discrepancies
      may result in delayed processing. '
    requiredSlot: {fileID: 11400000, guid: 1e070433b55e14a41888779db971575d, type: 2}
    timeToCompleteSeconds: 15
  - title: Federal Travel Preclearance
    promptText: Provide your passport number to proceed with travel authorization
      review.
    requiredSlot: {fileID: 11400000, guid: d4da788ecdbd30f41810cbdff1dd3a0e, type: 2}
    timeToCompleteSeconds: 15
  - title: Communication Reliability Assessment
    promptText: Enter the phone number currently associated with your identity record.
      Failure to provide a reachable number may affect status.
    requiredSlot: {fileID: 11400000, guid: d4da788ecdbd30f41810cbdff1dd3a0e, type: 2}
    timeToCompleteSeconds: 15
  - title: Supplemental Identity Clarification Document
    promptText: In order to continue the verification process, we ask that you review
      your submitted documents to ensure consistency with your legal name as it was
      originally recorded. It is essential that all fields are accurately completed
      according to existing records to avoid delays. If any discrepancies are found,
      further confirmation will be required.
    requiredSlot: {fileID: 11400000, guid: 1e070433b55e14a41888779db971575d, type: 2}
    timeToCompleteSeconds: 30
  - title: Driver Identification Status Reaffirmation
    promptText: Your information is being cross-checked to ensure compliance with
      all regulatory requirements. If your previous submissions contain errors, this
      will delay the form processing and may require an additional verification process.
      Please ensure that the number you provide is the same as the one previously
      associated with your legal driving status.
    requiredSlot: {fileID: 11400000, guid: 09917be0a746973449452c593d6a7185, type: 2}
    timeToCompleteSeconds: 30
  - title: Social Security Registration Continuity Verification
    promptText: In accordance with federal guidelines, please ensure that the correct
      identifier is used in this submission. Your current identification number must
      be provided to continue. If discrepancies are discovered, you will be required
      to submit documentation for further verification. Failure to do so may result
      in delays in processing your request.
    requiredSlot: {fileID: 11400000, guid: 0d6a7e9ad14d61c4aaa0bec153dc4e31, type: 2}
    timeToCompleteSeconds: 30
  - title: International Travel Documentation Confirmation
    promptText: This form is essential to validate your eligibility for international
      travel. While you may have previously submitted this information, it is necessary
      to confirm your details once again to ensure everything is accurate and up
      to date. Any discrepancies in this field may require further review, potentially
      delaying your approval.
    requiredSlot: {fileID: 11400000, guid: d4da788ecdbd30f41810cbdff1dd3a0e, type: 2}
    timeToCompleteSeconds: 30
  - title: Communication Record Alignment Request
    promptText: We are currently cross-referencing your contact information with
      existing records to ensure the accuracy of your file. It is vital that you
      verify your contact number in this section to avoid delays. If any inconsistencies
      are noted, the information provided will need to be corrected, which could
      result in further processing time.
    requiredSlot: {fileID: 11400000, guid: cce355572d7b20142994066dd6375e59, type: 2}
    timeToCompleteSeconds: 30
  - title: Identity Consistency Review Addendum
    promptText: 'To maintain consistency across the system, it is imperative that
      you confirm your legal name exactly as it appears in your records. Any deviations
      from previous submissions will trigger a review process. The name entered here
      must match your full legal identification to proceed. If any issues arise,
      you may be contacted for additional clarification. '
    requiredSlot: {fileID: 11400000, guid: 1e070433b55e14a41888779db971575d, type: 2}
    timeToCompleteSeconds: 30
  - title: Continued Eligibility Affirmation Statement
    promptText: Upon review of your prior submissions, a potential discrepancy has
      been identified in your eligibility records. To resolve this, we request that
      you enter the number as recorded. Failure to submit the correct data will initiate
      corrective actions, including further documentation requests. If this number
      does not match our records, we may need to request additional verification.
    requiredSlot: {fileID: 11400000, guid: 0d6a7e9ad14d61c4aaa0bec153dc4e31, type: 2}
    timeToCompleteSeconds: 30
